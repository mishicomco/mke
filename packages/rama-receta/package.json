{
  "name": "@mishicomco/rama-receta",
  "version": "0.1.0",
  "description": "Receta compartida del 'pod de rama' del harness v2 de Mishi Studio: generación PURA de manifiestos de k8s (Namespace/Secret/ConfigMap/Deployment/Service/Ingress) + slug/nombres/host. Consumida por el CLI `mke` y por Mishi Studio (encender/apagar in-cluster).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./src/ramaReceta.ts",
  "types": "./src/ramaReceta.ts",
  "exports": {
    ".": {
      "types": "./src/ramaReceta.ts",
      "default": "./src/ramaReceta.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mishicomco/mke.git",
    "directory": "packages/rama-receta"
  },
  "scripts": {
    "build": "tsc",
    "build:check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
